---
const { title, description, stack, slug } = Astro.props;
---

<a
  href={`/work/${slug}`}
  class="group block rounded-2xl border border-white/10 bg-white/[0.02] p-6 transition-all duration-300 hover:border-white/20 hover:bg-white/[0.04] hover:-translate-y-1"
>
  <div class="flex items-start justify-between">
    <div>
      <h3 class="text-xl font-medium text-white">
        {title}
      </h3>

      <p class="mt-3 text-sm leading-relaxed text-zinc-400 max-w-md">
        {description}
      </p>
    </div>

    <div class="text-zinc-600 transition-transform duration-300 group-hover:translate-x-1">
      →
    </div>
  </div>

  <div class="mt-6 text-xs text-zinc-500 tracking-wide">
    {stack}
  </div>
</a>
