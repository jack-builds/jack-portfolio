---
import ProjectCard from "./ProjectCard.astro";

const projects = [
  {
    title: "VoidUI",
    description:
      "A modern UI framework focused on clean design systems and developer experience.",
    stack: "ASTRO · TAILWIND · TYPESCRIPT",
    link: "#",
  },
  {
    title: "GlassBox",
    description:
      "A cybersecurity-focused project exploring modern tooling and monitoring concepts.",
    stack: "LINUX · SECURITY · AUTOMATION",
    link: "#",
  },
  {
    title: "StudyAce",
    description:
      "A lightweight productivity tool designed for students and focused workflows.",
    stack: "JAVASCRIPT · UX · WEB APP",
    link: "#",
  },
];
---

<section
  id="work"
  class="relative mx-auto max-w-5xl px-6 py-32"
>
  <div class="mb-16">
    <p class="text-sm uppercase tracking-[0.2em] text-zinc-500">
      Selected Work
    </p>

    <h2 class="mt-4 text-3xl md:text-5xl font-semibold tracking-tight">
      Projects that matter.
    </h2>
  </div>

  <div class="grid gap-6">
    {projects.map((project) => (
      <ProjectCard {...project} />
    ))}
  </div>
</section>